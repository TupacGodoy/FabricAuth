{
  "required": true,
  "package": "xyz.nikitacartes.easyauth.mixin",
  "compatibilityLevel": "JAVA_17",
  "mixins": [
    "CommandManagerMixin",
    "EntityMixin",
    "PlayerAdvancementTrackerMixin",
    "PlayerManagerMixin",
    //? if >=1.21 {
    "PlayerSaveHandlerMixin",
    //?} else {
    /*"WorldSaveHandlerMixin",
    *///?}
    "ServerLoginNetworkHandlerMixin",
    "ServerPlayerEntity$1Mixin",
    "ServerPlayerEntityMixin",
    "ServerPlayNetworkHandlerMixin",
    "SlotMixin",
    "CommandNodeAccessor"
  ],
  "minVersion": "0.8",
  "injectors": {
    "defaultRequire": 1
  },
  "refmap": "${refmap}"
}
